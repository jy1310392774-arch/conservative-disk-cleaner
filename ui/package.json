{
  "name": "conservative-disk-cleaner-ui",
  "version": "1.1.3",
  "private": true,
  "description": "Apple HIG inspired UI for Conservative Disk Cleaner",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && set DISK_CLEANER_DEV_SERVER=http://127.0.0.1:5173&& electron .\"",
    "build": "vite build",
    "start": "electron .",
    "package:win": "npm run build && electron-builder --win dir --x64"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "liquid-glass-react": "^1.1.1",
    "lucide-react": "^0.468.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "local.conservative.disk.cleaner",
    "productName": "Conservative Disk Cleaner",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "../ConservativeDiskCleaner.ps1",
        "to": "ConservativeDiskCleaner.ps1"
      }
    ],
    "win": {
      "target": [
        "dir"
      ]
    }
  }
}
